# Market worker — deploy to Fly.io / Render / Railway / any Node host
FROM node:22-alpine
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY worker ./worker
COPY src/lib ./src/lib
COPY src/types ./src/types
COPY tsconfig.json ./

# Production worker (env vars injected by host, not .env.local)
CMD ["npx", "tsx", "worker/market-worker.ts"]
